---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Pricing from '../components/Pricing.astro';
import Roadmap from '../components/Roadmap.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <Nav />
  <Hero />
  <Roadmap />
  <Pricing />
  <Footer />
</Layout>

<script>
  // ----- Showcase tabs: switch the displayed product card -----
  (() => {
    const tabs = Array.from(document.querySelectorAll<HTMLElement>('.showcase .tabs .tab'));
    const panels = Array.from(document.querySelectorAll<HTMLElement>('.showcase .frame .shot-img'));
    if (!tabs.length) return;

    const select = (tab: HTMLElement, focus = false) => {
      const key = tab.getAttribute('data-tab');
      tabs.forEach((t) => {
        const on = t === tab;
        t.classList.toggle('active', on);
        t.setAttribute('aria-selected', on ? 'true' : 'false');
        t.setAttribute('tabindex', on ? '0' : '-1');
      });
      panels.forEach((img) => img.classList.toggle('on', img.getAttribute('data-panel') === key));
      if (focus) tab.focus();
    };

    tabs.forEach((tab, i) => {
      tab.addEventListener('click', () => select(tab));
      tab.addEventListener('keydown', (e) => {
        let next = -1;
        if (e.key === 'ArrowRight' || e.key === 'ArrowDown') next = (i + 1) % tabs.length;
        else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') next = (i - 1 + tabs.length) % tabs.length;
        else if (e.key === 'Home') next = 0;
        else if (e.key === 'End') next = tabs.length - 1;
        if (next < 0) return;
        e.preventDefault();
        select(tabs[next], true);
      });
    });
  })();
</script>
