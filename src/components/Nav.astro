---
import Brand from './Brand.astro';
const GITHUB_URL = 'https://github.com/SpykeAutomation';
const DOCS_URL = 'https://docs.spykeautomation.com';
const APP_URL = 'https://app.spykeautomation.com';
---

<div class="navbar">
  <nav class="pill">
    <Brand href="/" />
    <div class="links" id="navLinks">
      <a href="/#product">Product</a>
      <a href={DOCS_URL}>Docs</a>
      <a href="/#pricing">Pricing</a>
      <a href={`${DOCS_URL}/company/`}>Company</a>
    </div>
    <div class="nav-cta">
      <a class="gh-ico" href={GITHUB_URL}>
        <svg viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0016 8c0-4.42-3.58-8-8-8z"/></svg><span class="gh-label">GitHub</span>
      </a>
      <a class="login" href={`${APP_URL}/login`}>Log In</a>
      <a class="btn btn-dark navbtn" href="#" data-access>Request Early Access</a>
      <button class="menu-toggle" id="menuToggle" type="button" aria-label="Open menu" aria-expanded="false" aria-controls="navLinks">
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>
</div>
