---
import Brand from './Brand.astro';
import ChevronTexture from './ChevronTexture.astro';
const GITHUB_URL = 'https://github.com/SpykeAutomation';
const DOCS_URL = 'https://docs.spykeautomation.com';
const year = 2026;
---

<footer class="site-footer">
  <ChevronTexture vw={1600} vh={440} stroke="#ffffff" className="foot-tex" seed={23} />
  <div class="wrap foot-top">
    <div class="foot-brand">
      <Brand href="/" />
    </div>
    <div class="foot-cols">
      <div class="fcol">
        <h4>Product</h4>
        <a href="/#product">Overview</a><a href="/#pricing">Pricing</a><a href={DOCS_URL}>Docs</a><a href="/#roadmap">Roadmap</a>
      </div>
      <div class="fcol">
        <h4>Company</h4>
        <a href={`${DOCS_URL}/company/`}>About</a><a href="mailto:hello@spykeautomation.com">Contact</a>
      </div>
      <div class="fcol">
        <h4>Resources</h4>
        <a href={GITHUB_URL}>GitHub</a><a href={`${DOCS_URL}/reference/cli/`}>CLI reference</a><a href={`${GITHUB_URL}/releases`}>Changelog</a>
      </div>
    </div>
  </div>
  <div class="wrap foot-base">
    <span>© {year} Spyke Automation</span>
    <span class="foot-legal"><a href="/privacy/">Privacy</a><a href="/terms/">Terms</a></span>
  </div>
</footer>
