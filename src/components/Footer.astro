---
import Brand from './Brand.astro';
import ChevronTexture from './ChevronTexture.astro';
const GITHUB_URL = 'https://github.com/SpykeAutomation';
const year = 2026;
---

<footer class="site-footer">
  <ChevronTexture vw={1600} vh={440} stroke="#ffffff" className="foot-tex" seed={23} />
  <div class="wrap foot-top">
    <div class="foot-brand">
      <Brand href="/" />
    </div>
    <div class="foot-cols">
      <div class="fcol">
        <h4>Product</h4>
        <a href="#">Overview</a><a href="#">Pricing</a><a href="#">Docs</a><a href="#">Roadmap</a>
      </div>
      <div class="fcol">
        <h4>Company</h4>
        <a href="#">About</a><a href="#">Blog</a><a href="#">Contact</a>
      </div>
      <div class="fcol">
        <h4>Resources</h4>
        <a href={GITHUB_URL}>GitHub</a><a href="#">CLI reference</a><a href="#">Changelog</a>
      </div>
    </div>
  </div>
  <div class="wrap foot-base">
    <span>© {year} Spyke Automation</span>
    <span class="foot-legal"><a href="#">Privacy</a><a href="#">Terms</a></span>
  </div>
</footer>
