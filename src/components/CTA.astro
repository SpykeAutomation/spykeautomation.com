---
const GITHUB_URL = 'https://github.com/SpykeAutomation';
const DOCS_URL = 'https://docs.spykeautomation.com';
---

<section class="cta">
  <div class="wrap rise" data-rise>
    <h2>Start tracking changes today</h2>
    <div class="cta-actions">
      <a class="btn btn-dark" href="/demo/">Schedule a demo</a>
      <a class="btn btn-ghost" href={DOCS_URL}>Read docs</a>
      <a class="btn btn-ghost" href={GITHUB_URL}>View on GitHub</a>
    </div>
  </div>
</section>
