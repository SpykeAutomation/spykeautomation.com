---
// Scattered "organized chaos" chevron texture — a jittered grid (even spacing,
// no overlaps) with random rotation/size per chevron. Generated at build time
// from a seed so the output is deterministic.
interface Props {
  vw?: number;
  vh?: number;
  cell?: number;
  jitter?: number;
  stroke?: string;
  className?: string;
  seed?: number;
  sMin?: number;
  sMax?: number;
}
const {
  vw = 1600,
  vh = 760,
  cell = 110,
  jitter = 22,
  stroke = '#16181D',
  className = 'grid-bg',
  seed = 7,
  sMin = 0.17,
  sMax = 0.38,
} = Astro.props;

function mulberry32(a: number) {
  return function () {
    a |= 0;
    a = (a + 0x6d2b79f5) | 0;
    let t = Math.imul(a ^ (a >>> 15), 1 | a);
    t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
  };
}

const rnd = mulberry32(seed);
const cols = Math.ceil(vw / cell);
const rows = Math.ceil(vh / cell);
const groups: string[] = [];
for (let r = 0; r < rows; r++) {
  for (let c = 0; c < cols; c++) {
    const cx = (c + 0.5) * cell + (rnd() * 2 - 1) * jitter;
    const cy = (r + 0.5) * cell + (rnd() * 2 - 1) * jitter;
    const s = sMin + rnd() * (sMax - sMin);
    const rot = rnd() * 360;
    groups.push(
      `<g transform="translate(${cx.toFixed(0)},${cy.toFixed(0)}) rotate(${rot.toFixed(0)}) scale(${s.toFixed(2)}) translate(-50 -48)"><path d="M22 46 L50 22 L78 46"/><path d="M22 74 L50 50 L78 74"/></g>`,
    );
  }
}
const inner = groups.join('');
---

<svg class={className} aria-hidden="true" viewBox={`0 0 ${vw} ${vh}`} preserveAspectRatio="xMidYMid slice">
  <g fill="none" stroke={stroke} stroke-width="13" stroke-linecap="round" stroke-linejoin="round" set:html={inner}></g>
</svg>
