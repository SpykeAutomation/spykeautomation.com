---
// Request-access modal. Opened by any element with a [data-access] attribute.
// Submits to a form service (set PUBLIC_FORM_ENDPOINT) — see index.astro script.
---

<div class="modal-overlay" id="accessModal" aria-hidden="true">
  <div class="modal" role="dialog" aria-modal="true" aria-label="Request early access">
    <button class="x" type="button" aria-label="Close">&times;</button>
    <div class="m-intro">
      <svg class="m-logo" viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="13" stroke-linecap="round" stroke-linejoin="round">
        <path d="M22 46 L50 22 L78 46" /><path d="M22 74 L50 50 L78 74" />
      </svg>
      <h3>Request early access</h3>
      <p>Spyke is in private beta. Leave your email and we'll reach out when a spot opens.</p>
      <form id="accessForm" novalidate>
        <input type="email" name="email" placeholder="you@company.com" required autocomplete="email" />
        <button type="submit" class="btn btn-dark btn-lg m-cta">Request access</button>
      </form>
      <div class="m-note">No spam — only about your beta access.</div>
    </div>
    <div class="m-done">
      <div class="check">
        <svg viewBox="0 0 24 24"><path d="M5 13l4 4L19 7" /></svg>
      </div>
      <h3>You're on the list.</h3>
      <p>Thanks — we'll be in touch when a beta spot opens up.</p>
      <button type="button" class="btn btn-out btn-lg m-cta m-close2" style="margin-top:18px;">Close</button>
    </div>
  </div>
</div>
