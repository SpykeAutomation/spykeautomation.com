---
const APP_URL = 'https://app.spykeautomation.com';
const DOCS_URL = 'https://docs.spykeautomation.com';
---

<section class="hero-si">
  <div class="wrap">
    <div class="hero-copy">
      <h1>Keep a clear record of every PLC program you deliver.</h1>
      <p class="sub">
        Spyke helps systems integrators save, compare, and review Studio 5000
        program versions from development through FAT, commissioning, and
        handover. Spyke gives the team one place to see what changed
        between versions and why.
      </p>
      <div class="hero-actions">
        <a class="btn btn-dark" href={APP_URL}>Get started</a>
        <a class="btn btn-ghost" href={DOCS_URL}>Read docs</a>
      </div>
    </div>
  </div>

  {/*
    The Spyke compare view. The markup rests in the finished comparison —
    FAT and SAT selected, diff visible — and the script below replays the
    selection with a scripted pointer once the demo scrolls into view. With
    reduced motion or no JS, viewers simply see the finished comparison.
  */}
  <div class="siviz-holder">
    <div class="siapp" id="siApp" data-si="compare"
         role="img"
         aria-label="The Spyke app comparing two saved versions of the Packaging Line 3 program. A versions sidebar lists Dev, FAT, Commissioning, SAT, and As-left. FAT and SAT are selected, and the diff pane highlights what changed: two safety contacts and a MOV of 140 added, marked in green, and a timer-done contact removed, marked in red — three additions and one removal across two rungs.">
      <div class="siapp-bar">
        <svg class="siapp-logo" viewBox="0 0 20 20" aria-hidden="true"><path d="M4 11l6-5 6 5M4 15l6-5 6 5"/></svg>
        <span class="siapp-mark">Spyke</span>
        <span class="siapp-crumb"><b>Packaging Line 3</b><span class="siapp-sep">/</span>Compare versions</span>
      </div>
