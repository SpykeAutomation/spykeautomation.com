          <div class="side-head">Versions</div>
          <div class="side-list">
            <div class="ver" data-ver="dev"><span class="ver-box"><svg viewBox="0 0 14 14" aria-hidden="true"><path d="M3 7.3 6 10l5-6"/></svg></span><span class="ver-title">Dev</span><span class="ver-meta"><span class="ver-date">May 28</span><span class="ver-author">Alex</span></span></div>
            <div class="ver" data-ver="fat"><span class="ver-box"><svg viewBox="0 0 14 14" aria-hidden="true"><path d="M3 7.3 6 10l5-6"/></svg></span><span class="ver-title">FAT</span><span class="ver-meta"><span class="ver-date">Jun 12</span><span class="ver-author">Alex</span></span></div>
            <div class="ver" data-ver="comm"><span class="ver-box"><svg viewBox="0 0 14 14" aria-hidden="true"><path d="M3 7.3 6 10l5-6"/></svg></span><span class="ver-title">Commissioning</span><span class="ver-meta"><span class="ver-date">Jun 20</span><span class="ver-author">Maya</span></span></div>
            <div class="ver" data-ver="sat"><span class="ver-box"><svg viewBox="0 0 14 14" aria-hidden="true"><path d="M3 7.3 6 10l5-6"/></svg></span><span class="ver-title">SAT</span><span class="ver-meta"><span class="ver-date">Jul 3</span><span class="ver-author">Maya</span></span></div>
            <div class="ver" data-ver="asleft"><span class="ver-box"><svg viewBox="0 0 14 14" aria-hidden="true"><path d="M3 7.3 6 10l5-6"/></svg></span><span class="ver-title">As-left</span><span class="ver-meta"><span class="ver-date">Jul 9</span><span class="ver-author">Alex</span></span></div>
          </div>
