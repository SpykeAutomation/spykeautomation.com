---
import ChevronTexture from './ChevronTexture.astro';
const GITHUB_URL = 'https://github.com/SpykeAutomation';
---

<section class="hero">
  <div class="wrap hero-center">
    <h1>
      <span class="em">Open-source version control</span><br />
      <span class="em">system for</span> <span class="mu">Industrial Automation</span>
    </h1>
    <div class="cta-row">
      <a class="btn btn-dark btn-lg" href="#" data-access>Request Early Access</a>
      <a class="btn btn-out btn-lg" href={GITHUB_URL}>
        <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>View on GitHub
      </a>
    </div>
  </div>

  <!-- SHOWCASE -->
  <div class="showcase">
    <div class="wrap">
      <div class="tabs">
        <div class="tab active" data-tab="ladder">
          <svg viewBox="0 0 24 24"><path d="M4 6h7M4 12h10M4 18h6" /><circle cx="17" cy="7" r="2" /></svg>Ladder Logic
        </div>
        <div class="tab" data-tab="st">
          <svg viewBox="0 0 24 24"><path d="M9 8l-4 4 4 4M15 8l4 4-4 4" /></svg>Structured Text
        </div>
      </div>
    </div>
    <div class="stage">
      <ChevronTexture vw={1600} vh={760} stroke="#16181D" className="grid-bg" seed={7} />
      <div class="frame">
        <img class="shot-img on" data-panel="ladder" src="/hero_card.png" alt="Ladder-logic semantic diff between versions v14 and v15" />
        <img class="shot-img" data-panel="st" src="/st_card.png" alt="Structured Text unified diff between versions v14 and v15" />
      </div>
    </div>
  </div>
</section>
